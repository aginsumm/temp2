# 应用配置
APP_NAME=非遗数字生命互动引擎
APP_VERSION=1.0.0
DEBUG=True

# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./heritage.db

# CORS 配置
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000","http://127.0.0.1:5173","http://26.14.142.136:3000","http://26.14.142.136:5173"]

# JWT 配置（生产环境请修改）
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ========== AI API 配置（重要）==========
# 以下配置决定系统是否使用真实的 AI 服务
# 如果留空，系统将使用模拟数据（mock）降级运行

# 阿里云通义千问 API（推荐）
# 获取方式：https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here

# OpenAI API（备选）
# 获取方式：https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ========== 可选配置 ==========

# Neo4j 图数据库（如果不配置，使用 SQLite）
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your-password

# Redis 缓存（可选）
# REDIS_URL=redis://localhost:6379

# Milvus 向量数据库（如果不配置，使用本地检索）
# MILVUS_HOST=localhost
# MILVUS_PORT=19530
