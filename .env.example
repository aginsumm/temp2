# 非遗数字生命互动引擎 - 环境变量配置
# 
# 本文件定义了应用运行所需的环境变量
# 复制此文件为 .env.local 并填写实际值
#
# @author 非遗数字生命互动引擎项目组
# @version 1.0.0

# ==================== API 配置 ====================

# 后端 API 基础地址
# 开发环境: http://localhost:8000/api/v1
# 生产环境: https://your-domain.com/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1

# WebSocket 服务地址（用于实时通信）
# 开发环境: ws://localhost:8000/api/v1/ws
# 生产环境: wss://your-domain.com/api/v1/ws
VITE_WS_URL=ws://localhost:8000/api/v1/ws

# 健康检查地址
VITE_HEALTH_CHECK_URL=http://localhost:8000/health

# ==================== 大模型服务配置 ====================
# 【后端扩展说明】
# 当集成真实大模型服务时，取消以下注释并配置

# 通义千问 API Key（阿里云）
# VITE_DASHSCOPE_API_KEY=your_dashscope_api_key

# 文心一言 API Key（百度）
# VITE_WENXIN_API_KEY=your_wenxin_api_key

# OpenAI API Key（可选，用于竞赛演示）
# VITE_OPENAI_API_KEY=your_openai_api_key

# 大模型服务选择: dashscope | wenxin | openai | mock
VITE_LLM_PROVIDER=mock

# ==================== 功能开关 ====================

# 是否启用离线模式（true/false）
# 设置为 true 时，所有功能将使用本地实现
VITE_OFFLINE_MODE=false

# 是否启用数据同步（true/false）
# 设置为 true 时，离线操作将在网络恢复后同步到后端
VITE_ENABLE_SYNC=true

# 是否启用调试模式（true/false）
VITE_DEBUG_MODE=true

# ==================== 存储配置 ====================

# IndexedDB 数据库名称
VITE_DB_NAME=HeritageAppDB

# 本地存储过期时间（毫秒）
VITE_CACHE_TTL=86400000

# 最大会话数量
VITE_MAX_SESSIONS=100

# 每个会话最大消息数
VITE_MAX_MESSAGES_PER_SESSION=500

# ==================== 地图服务配置 ====================
# 【后端扩展说明】
# 当启用地图视图时，配置高德地图 API Key

# 高德地图 API Key
# VITE_AMAP_KEY=your_amap_key

# ==================== 分析与监控 ====================
# 【后端扩展说明】
# 生产环境建议配置错误监控服务

# Sentry DSN（错误监控）
# VITE_SENTRY_DSN=your_sentry_dsn

# Google Analytics ID
# VITE_GA_ID=your_ga_id
