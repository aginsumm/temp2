.env
.env.local
.env.*.local
.env.example.bak

# ============================================
# 构建产物
# ============================================
dist/
build/
output/
coverage/
*.local

# ============================================
# TypeScript 编译缓存
# ============================================
*.tsbuildinfo

# ============================================
# 测试覆盖率
# ============================================
.nyc_output/

# ============================================
# 打包器缓存
# ============================================
.cache/
.parcel-cache/
.vite/

# ============================================
